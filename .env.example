# LLM provider — any provider supported by LiteLLM
# Examples: openai/gpt-4o, anthropic/claude-sonnet-4-6, gemini/gemini-1.5-pro
LITELLM_MODEL=anthropic/claude-sonnet-4-6
LITELLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# API keys — set the one(s) matching your chosen provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Pipeline tier thresholds
DIVERGENCE_THRESHOLD=0.15
DRIFT_THRESHOLD=0.20
PRECOMMITMENT_CONSISTENCY_THRESHOLD=0.6

# Tier activation: true/false
TIER_NORMALIZATION=true
TIER_COUNTERFACTUAL=true
TIER_PRECOMMITMENT=true
TIER_DISAGREEMENT=true
TIER_TEMPORAL=true
